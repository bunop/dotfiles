#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
    echo "Usage: $(basename "$0") <module>"
    echo "  Available modules: $(ls -d "${DOTFILES_DIR}"/*/  | xargs -n1 basename | tr '\n' ' ')"
    exit 1
}

[[ $# -eq 1 ]] || usage

MODULE="$1"
SRC_DIR="${DOTFILES_DIR}/${MODULE}"

[[ -d "${SRC_DIR}" ]] || { echo "ERROR: module '${MODULE}' not found (${SRC_DIR})"; exit 1; }

install_file() {
    local src="$1"
    # relative path from SRC_DIR, e.g. "bashrc" or "R/Makevars"
    local rel="${src#${SRC_DIR}/}"
    # first path component gets a dot prefix: "bashrc" -> ".bashrc", "R/Makevars" -> ".R/Makevars"
    local target="${HOME}/.${rel}"
    local target_dir
    target_dir="$(dirname "${target}")"

    # Ensure parent directory exists (for nested paths like ~/.R/)
    if [[ ! -d "${target_dir}" ]]; then
        mkdir -p "${target_dir}"
        echo "created dir: ${target_dir}"
    fi

    # Already the correct symlink — skip
    if [[ -L "${target}" && "$(readlink -f "${target}")" == "$(readlink -f "${src}")" ]]; then
        echo "already linked: ${target}"
        return 0
    fi

    # Target exists (regular file or wrong symlink) — back it up
    if [[ -e "${target}" || -L "${target}" ]]; then
        local bak="${target}.bak"
        if [[ -e "${bak}" || -L "${bak}" ]]; then
            echo "SKIP: backup already exists: ${bak}"
            return 1
        fi
        echo "backup: ${target} -> ${bak}"
        mv "${target}" "${bak}"
    fi

    ln -s "${src}" "${target}"
    echo "linked: ${target} -> ${src}"
}

while IFS= read -r -d '' src_file; do
    install_file "${src_file}"
done < <(find "${SRC_DIR}" -type f -print0 | sort -z)
