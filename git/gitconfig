[color]
	ui = true
[credential]
	helper = manager
[format]
	pretty = %h - %an, %ar : %s
[merge]
	tool = vimdiff
[user]
	name = Paolo Cozzi
	email = paoloalessandro.cozzi@gmail.com
[alias]
	mytree = log --all --decorate --oneline --graph
	# http://stackoverflow.com/questions/1753070/git-ignore-files-only-locally
	ignore = update-index --assume-unchanged
	unignore = update-index --no-assume-unchanged
	ignored = !git ls-files -v | grep "^[[:lower:]]"
	# https://coderwall.com/p/n1d-na/excluding-files-from-git-locally
	exclude = "!f() { echo \"$1\" >> .git/info/exclude; }; f"
[push]
	default = simple
[status]
	submoduleSummary = true
[diff]
	submodule = log
[fetch]
	recurseSubmodules = on-demand
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	ff = only
[core]
	excludesFile = ~/.gitignore
